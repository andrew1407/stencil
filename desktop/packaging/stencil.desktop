[Desktop Entry]
Type=Application
Name=Stencil
GenericName=Image Annotator
Comment=Load an image, draw polylines and rectangles over it, edit points, and save your work
# %u passes a launcher/file-manager-selected file OR a stencil:// deep link as a
# positional arg, opened by openPathFromOS / parseStencilUrl (image/video ->
# editor, *.json -> layout, stencil://open?... -> deep link).
Exec=stencil_gui %u
Icon=stencil
Terminal=false
Categories=Graphics;2DGraphics;RasterGraphics;
Keywords=image;annotation;drawing;polyline;rectangle;
# File associations: double-click / "Open With" in the file manager launches the
# app with the file as a positional arg. x-scheme-handler/stencil routes
# stencil:// deep links (the cross-front-end "Open in…" feature) here too.
MimeType=image/png;image/jpeg;image/bmp;image/gif;image/webp;video/mp4;video/quicktime;video/webm;video/x-matroska;application/json;application/x-stencil;x-scheme-handler/stencil;
# Right-click (Jump-list-style) launcher actions.
Actions=Incognito;Projects;

[Desktop Action Incognito]
Name=New Incognito Editor
Exec=stencil_gui --incognito

[Desktop Action Projects]
Name=Open Projects
Exec=stencil_gui --projects
