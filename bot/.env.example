# Stencil Telegram bot — configuration template.
#
# Copy this to `.env` (which is gitignored) and adjust:
#
#   cp bot/.env.example bot/.env
#
# Real environment variables always win over values in `.env`. Only TELEGRAM_BOT_TOKEN is
# required; everything else has a sensible default.

# REQUIRED. Your bot token from @BotFather (https://t.me/BotFather → /newbot).
# Without it the bot prints a hint and exits. Never commit the real token.
TELEGRAM_BOT_TOKEN=

# Path to the Stencil CLI binary (the pixel engine the bot shells out to, exactly like
# mcp/). Default: auto-discovered — the repo's cli/zig-out/bin/stencil, then `stencil` on
# PATH. Build it with `zig build` in cli/ first.
#STENCIL_CLI=/absolute/path/to/cli/zig-out/bin/stencil

# Optional Redis URL for per-user session state (working image + edits + connections +
# active project), the same store the Go server uses for fan-out. When empty the bot keeps
# sessions in memory (single-instance, lost on restart) — fine for dev and tests.
#REDIS_URL=redis://localhost:6379/0

# Scratch directory for per-user working images and rendered results. Default: a
# `stencil-bot` folder under the OS temp dir.
#STENCIL_BOT_DATA_DIR=/tmp/stencil-bot

# Accept self-signed TLS certs when connecting to https collaboration servers (dev only).
# Default false (certificates are verified).
#STENCIL_TLS_INSECURE=false
