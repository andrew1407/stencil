<?xml version="1.0" encoding="utf-8"?>
<!--
  Restore every NuGet dependency into a repo-local folder (bot/packages/) instead of the
  machine-global ~/.nuget/packages cache. This keeps the bot's dependencies self-contained
  and off the global cache — the folder is git-ignored (like node_modules) and refilled by
  `dotnet restore`. globalPackagesFolder is resolved relative to this file, so it applies to
  every project in the solution.
-->
<configuration>
  <packageSources>
    <clear />
    <add key="nuget.org" value="https://api.nuget.org/v3/index.json" protocolVersion="3" />
  </packageSources>
  <config>
    <add key="globalPackagesFolder" value="packages" />
  </config>
</configuration>
