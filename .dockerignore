# Build context is the repo root (the browser/CLI images both compile core/).
# Keep the context small: drop VCS, build outputs, caches and OS cruft.

.git
.github
**/.DS_Store

# Generated / build outputs
core/build
core/build-wasm
desktop/build
desktop/build-wasm
desktop/CMakeFiles
cli/zig-out
cli/zig-cache
cli/.zig-cache
cli/zig-pkg
browser/js/wasm

# Parts not used by the browser or CLI images
desktop
extension

# .NET bot: build output + local config. NEVER ship .env (it holds the bot token);
# the token is supplied at runtime via -e TELEGRAM_BOT_TOKEN. packages/ is the host's
# local NuGet restore cache — the image restores its own copy, so keep it out of context.
**/.env
bot/**/bin
bot/**/obj
bot/packages

# Go server: local dependency copy from `go mod vendor` (not shipped in these images).
server/vendor

# Docs / editor
**/*.md
.claude
