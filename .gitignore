# OS
.DS_Store
Thumbs.db

# Editors
.vscode/
.idea/
*.swp
*~

# Claude Code: ignore the local/personal harness state (settings.local.json, locks,
# scheduler/session files) but keep the version-controlled, shared harness: the
# shared permissions/hook wiring, the security guard hook, the rules, skills, and agents.
# settings.local.json stays ignored (still matched by .claude/*).
.claude/*
!.claude/settings.json
!.claude/skills/
!.claude/agents/
!.claude/hooks/
!.claude/rules/

# Node (only used for `node --test`; no deps committed)
node_modules/
npm-debug.log*

# E2E harness (e2e/): Playwright deps + generated reports/traces. The suites and
# helpers are committed; the report artifacts and installed browsers are not.
e2e/playwright-report/
e2e/test-results/
e2e/blob-report/

# Logs / temp
*.log
*.tmp

# C++ / CMake build output (desktop/ app). build-wasm/ is the Emscripten output
# dir; the SINGLE_FILE module copied from it (browser/js/wasm/stencilCore.js) is a
# generated artifact too — built in CI (and on demand locally, see desktop/WASM.md),
# not committed.
build/
build-wasm/
*.o
*.obj
*.a
*.so
*.dylib
CMakeCache.txt
CMakeFiles/
cmake_install.cmake
compile_commands.json

# Qt
*.moc
moc_*.cpp
moc_*.h
qrc_*.cpp
ui_*.h
.qmake.stash
*.autosave

# Desktop app runtime state (settings / session / projects) — repo-local, never committed
.stencil/
desktop/.stencil/

# Core test dependency — doctest single header is fetched on demand, not committed
# (see core/README via README → Test). Keeps the ~300 KB vendored header out of the repo.
core/third_party/doctest.h
# Desktop never vendors its own third-party headers — its C++ tests are QtTest, and any
# doctest it needs comes from core/'s fetched copy. Guard the dir so a stray header can't be
# re-committed by accident (it was once, in a large reorg, and had to be scrubbed).
desktop/third_party/

# Browser "Open in…" targets (desktop scheme + optional Telegram bot username) — the
# static-site equivalent of a .env: the committed openInConfig.example.json is the
# template; the real openInConfig.json is per-operator and never committed (the app
# falls back to built-in defaults when it's absent).
browser/js/config/openInConfig.json

# Local capture artifact from the Open-in verification (chrome-devtools screenshot dump).
browser/.stencil-open-in-capture.json
browser/.desktop-check.png

# Generated WebAssembly core — Emscripten output copied from core/build-wasm/
# (see core/WASM.md). Built in CI for the parity check; build locally to exercise
# the wasm path. The JS reference/fallback path runs without it.
browser/js/wasm/stencilCore.js

# Zig CLI (cli/) build output and the on-demand package cache (stb etc.), neither
# committed. zig-out/ is `zig build` output; .zig-cache/ and zig-pkg/ are local caches.
cli/zig-out/
cli/.zig-cache/
cli/zig-pkg/
.zig-cache/

# Rust MCP server (mcp/) build output. target/ is `cargo build` output; Cargo.lock is
# committed (this is a binary crate).
mcp/target/
# Local server config — secrets/paths per machine. The committed mcp/.env.example is the
# template; the real mcp/.env is never committed.
mcp/.env

# Go collaboration server (server/). Local config + filestore data + any built binary.
# The committed server/.env.example is the template; the real server/.env is never
# committed. go.sum IS committed. vendor/ is the local dependency copy produced by
# `go mod vendor` (node_modules-style: regenerated on demand, not committed); Go builds
# use it automatically instead of the machine-global module cache (~/go/pkg/mod).
server/.env
server/data/
server/stencil-server
server/vendor/

# Python package (pystencil/): on-demand compiled core artifact + Python build cruft.
pystencil/pystencil/_native/
__pycache__/
*.py[cod]
*.egg-info/
dist/
.pytest_cache/

# .NET Telegram bot (bot/): build output + per-machine config. bin/ and obj/ are
# `dotnet build` output; the committed bot/.env.example is the template, the real
# bot/.env (holding the bot token) is never committed. packages/ is the repo-local
# NuGet restore folder (see bot/nuget.config): node_modules-style, refilled by
# `dotnet restore` instead of the machine-global ~/.nuget/packages cache — not committed.
bot/**/bin/
bot/**/obj/
bot/.env
bot/packages/
