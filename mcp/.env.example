# Stencil MCP server — configuration template.
#
# Copy this to `.env` (which is gitignored) and adjust. Every value is OPTIONAL: sensible
# defaults are used when unset. Precedence, lowest to highest:
#
#   built-in defaults  <  this .env file  <  process env / mcpServers "env"  <  --surface arg
#
# and a per-call `surface` parameter on a tool overrides the default for that one call.

# Default delivery surface(s) for stencil_edit results. An env var is a STRING, so use a
# comma list (a bracketed ["cli","browser"] string is also accepted). The per-call
# `surface` tool parameter additionally takes a real JSON array.
# The CLI always does the pixel work; these control where the result is delivered:
#   cli           write the output file (always implied)
#   desktop       also launch the Qt desktop app showing the result
#   browser       also build/open an editor launch URL with the result loaded
#   browser-live  delegated: live driving is handled by the stencil-operator agent
#   extension     delegated: page scanning is handled by the stencil-operator agent
STENCIL_SURFACES=cli,browser

# Path to the Stencil CLI binary. Default: auto-discovered (the repo's
# cli/zig-out/bin/stencil, then `stencil` on PATH).
#STENCIL_CLI=/absolute/path/to/stencil

# Path to the Qt desktop binary (used by the `desktop` surface).
# Default: <repo>/desktop/build/stencil_gui.
#STENCIL_DESKTOP=/absolute/path/to/stencil_gui

# Base URL of the served browser editor. Only needed for the `browser`/`browser-live`/
# `extension` surfaces, and only if the editor is NOT on the default below (e.g. you ran
# `ADDR=0.0.0.0 PORT=3000 npm run serve`, or it's on another host). Ignored for cli/desktop.
#STENCIL_BROWSER_URL=http://localhost:8080

# Auto-open the browser launch URL with the OS opener (open / xdg-open). When false the
# URL is just returned in the tool result for you to open. Default: false.
#STENCIL_AUTO_OPEN=false
