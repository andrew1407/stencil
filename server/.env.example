# Stencil collaboration server configuration.
# Copy to .env and adjust. Real environment variables override .env values.

# HTTP/WebSocket listener.
LISTEN_ADDR=:8090

# Raw-TCP (NDJSON) edit listener for the desktop (QTcpSocket) and CLI (std.Io.net).
# The CLI subscribes here read-only for live "project updated" events while syncing.
TCP_ADDR=:8091

# Postgres connection string (pgx). Required.
DATABASE_URL=postgres://stencil:stencil@localhost:5432/stencil?sslmode=disable

# Redis URL for cross-instance edit/event fan-out. Optional: when empty the
# server uses an in-process bus (single-instance only).
REDIS_URL=redis://localhost:6379/0

# Root directory for the secured file store (image bytes).
FILESTORE_ROOT=./data/filestore

# When set, POST /auth/token requires this admin token (X-Admin-Token header or
# Authorization: Bearer). Leave empty for open token issuance in development.
ADMIN_TOKEN=

# Comma-separated browser origins allowed to call the REST API cross-origin
# (the browser/ app and the Chrome extension). "*" (default) reflects any
# origin; set an explicit list (e.g. http://localhost:8080) to lock it down.
CORS_ORIGINS=*

# Issued-token lifetime in hours (default 168 = 7 days).
TOKEN_TTL_HOURS=168

# Max REST request body in bytes (default 33554432 = 32 MiB).
MAX_BODY_BYTES=33554432

# Project expiration. Server projects have NO expiry by default — clients set one
# explicitly (the editor's `expire` command). PROJECT_TTL_HOURS, when > 0, stamps a
# default expiry (now + TTL) on every new project that arrives without one; 0/unset
# = off. The server sweeps expired projects (removing DB row + image bytes and
# notifying clients) at startup and every EXPIRY_SWEEP_MINUTES thereafter; set the
# interval to 0 to disable the sweep.
PROJECT_TTL_HOURS=0
EXPIRY_SWEEP_MINUTES=60

# Optional TLS. When both are set the same cert/key secures HTTPS + WSS on
# LISTEN_ADDR *and* the raw-TCP edit channel on TCP_ADDR (TLS 1.2 minimum).
# Leave blank only behind a trusted TLS-terminating proxy or on localhost.
TLS_CERT=
TLS_KEY=
